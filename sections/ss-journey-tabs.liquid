{{ 'sleep-suite.css' | asset_url | stylesheet_tag }}
<section class="section ss-journey">
  <div class="container">

    {%- if section.settings.label != blank -%}
    <p class="ss-journey__label">{{ section.settings.label }}</p>
    {%- endif -%}

    <div class="ss-journey__tabs">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tab' -%}
        <div class="ss-journey__tab{% if forloop.first %} is-active{% endif %}" data-filter="{{ block.settings.filter }}" {{ block.shopify_attributes }}>
          <div class="ss-journey__tab-num">{{ block.settings.number }}</div>
          <div class="ss-journey__tab-name">{{ block.settings.name }}</div>
          <div class="ss-journey__tab-desc">{{ block.settings.description }}</div>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "SS Journey Tabs",
  "tag": "section",
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "filter",
          "label": "Filter value",
          "info": "Must match the category value on the product section (e.g. system, schlafklima, sinne, recovery)"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Tab name",
          "default": "Das System"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Tab description",
          "default": "Ideale Körperlage. Rücken, Nacken & Wirbelsäule perfekt gestützt."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Der Weg zu tiefem, erholsamem Schlaf"
    }
  ],
  "presets": [
    {
      "name": "SS Journey Tabs",
      "blocks": [
        { "type": "tab", "settings": { "filter": "system", "number": "01", "name": "Das System", "description": "Ideale Körperlage. Rücken, Nacken & Wirbelsäule perfekt gestützt." } },
        { "type": "tab", "settings": { "filter": "schlafklima", "number": "02", "name": "Schlafklima", "description": "Richtige Temperatur. Muskeln entspannen, Tiefschlaf wird möglich." } },
        { "type": "tab", "settings": { "filter": "sinne", "number": "03", "name": "Sinne & Geist", "description": "Ruhe für alle Sinne. Psyche entlastet, natürlich einschlafen." } },
        { "type": "tab", "settings": { "filter": "recovery", "number": "04", "name": "Recovery", "description": "Von innen regenerieren. Körper mit dem Richtigen versorgen." } }
      ]
    }
  ]
}
{% endschema %}
