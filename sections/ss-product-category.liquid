{{ 'sleep-suite.css' | asset_url | stylesheet_tag }}
<section class="section ss-section" data-category="{{ section.settings.category }}">
  <div class="container">

    <div class="ss-section__header">
      <div class="ss-section__header-top">
        <h2 class="ss-section__title">{{ section.settings.title }}</h2>
        {%- if section.settings.tag_text != blank -%}
        <span class="ss-tag ss-tag--light">{{ section.settings.tag_text }}</span>
        {%- endif -%}
      </div>
      {%- if section.settings.description != blank -%}
      <p class="ss-section__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
    <div class="ss-grid ss-grid--{{ section.settings.grid_cols }}"{% if section.settings.max_width != blank %} style="max-width: {{ section.settings.max_width }}"{% endif %}>
      {%- for block in section.blocks -%}
        {%- if block.type == 'product_card' -%}
        <div class="ss-pcard-light" {{ block.shopify_attributes }}>
          <div class="ss-pcard-light__img {{ block.settings.bg_class }}">
            <div class="ss-pcard-light__tags">
              {%- if block.settings.tag != blank -%}
              <span class="ss-tag ss-tag--light">{{ block.settings.tag }}</span>
              {%- endif -%}
              {%- if block.settings.show_new -%}
              <span class="ss-tag ss-tag--neu">Neu</span>
              {%- endif -%}
            </div>
            {%- if block.settings.image -%}
            <img width="380" height="240" src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.image.alt | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="ss-pcard-light__body">
            {%- if block.settings.name != blank -%}
            <div class="ss-pcard-light__name">{{ block.settings.name }}</div>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
            <p class="ss-pcard-light__desc{% if block.settings.highlight_desc %} ss-pcard-light__desc--highlight{% endif %}">
              {{ block.settings.description }}
            </p>
            {%- endif -%}
            {%- if block.settings.compare_button != blank -%}
            <button class="ss-pcard-light__btn">{{ block.settings.compare_button }}</button>
            {%- elsif block.settings.button_text != blank -%}
            <a href="{{ block.settings.button_url }}" class="btn">
              <b>{{ block.settings.button_text }}</b>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            {%- endif -%}
          </div>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "SS Product Category",
  "tag": "section",
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "bg_class",
          "label": "Background class",
          "default": "ss-imgbg--sage",
          "info": "e.g. ss-imgbg--sage, ss-imgbg--olive, ss-imgbg--mauve, ss-imgbg--teal"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag text"
        },
        {
          "type": "checkbox",
          "id": "show_new",
          "label": "Show \"Neu\" badge",
          "default": false
        },
        {
          "type": "text",
          "id": "name",
          "label": "Product name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "checkbox",
          "id": "highlight_desc",
          "label": "Highlight description style",
          "default": false
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Entdecke"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link"
        },
        {
          "type": "text",
          "id": "compare_button",
          "label": "Compare button text",
          "info": "If set, renders a compare button instead of the link button"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "category",
      "label": "Category filter value",
      "info": "Must match the filter buttons (e.g. system, schlafklima, sinne, recovery)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title"
    },
    {
      "type": "text",
      "id": "tag_text",
      "label": "Header tag"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section description"
    },
    {
      "type": "select",
      "id": "grid_cols",
      "label": "Cards per row",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "2"
    },
    {
      "type": "text",
      "id": "max_width",
      "label": "Max width override",
      "info": "Optional, e.g. 540px. Leave blank for full width."
    }
  ],
  "presets": [
    {
      "name": "SS Product Category"
    }
  ]
}
{% endschema %}
