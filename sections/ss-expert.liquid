{{ 'sleep-suite.css' | asset_url | stylesheet_tag }}
<section class="section ss-expert">
  <div class="container">

    <!-- Expert quote card -->
    <div class="ss-expert__card">
      {%- if section.settings.eyebrow != blank -%}
      <span class="ss-expert__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.quote != blank -%}
      <blockquote class="ss-expert__quote">{{ section.settings.quote }}</blockquote>
      {%- endif -%}
      {%- if section.settings.avatar -%}
      <div class="ss-expert__avatar">
        <img width="80" height="80" src="{{ section.settings.avatar | img_url: '160x160' }}" alt="{{ section.settings.expert_name | escape }}" loading="lazy">
      </div>
      {%- endif -%}
      {%- if section.settings.expert_name != blank -%}
      <div class="ss-expert__name">{{ section.settings.expert_name }}</div>
      {%- endif -%}
      {%- if section.settings.expert_role != blank -%}
      <div class="ss-expert__role">{{ section.settings.expert_role }}</div>
      {%- endif -%}
    </div>

    <!-- Trust badges -->
    {%- if section.blocks.size > 0 -%}
    <div class="ss-trust">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust_badge' -%}
        <div class="ss-trust__card" {{ block.shopify_attributes }}>
          <svg class="ss-trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 3h12l3 7-9 11L3 10z"/>
          </svg>
          {%- if block.settings.name != blank -%}
          <div class="ss-trust__name">{{ block.settings.name }}</div>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
          <p class="ss-trust__desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- endif -%}

    <!-- CTA -->
    {%- if section.settings.cta_title != blank or section.settings.cta_desc != blank -%}
    <div class="ss-cta">
      <div>
        {%- if section.settings.cta_title != blank -%}
        <div class="ss-cta__title">{{ section.settings.cta_title }}</div>
        {%- endif -%}
        {%- if section.settings.cta_desc != blank -%}
        <p class="ss-cta__desc">{{ section.settings.cta_desc }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_url }}" class="btn">
        <b>{{ section.settings.cta_text }}</b>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      {%- endif -%}
    </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "SS Expert & Trust",
  "tag": "section",
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Badge name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Badge description"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Expert quote"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Experteneinblick"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote text"
    },
    {
      "type": "image_picker",
      "id": "avatar",
      "label": "Expert photo"
    },
    {
      "type": "text",
      "id": "expert_name",
      "label": "Expert name",
      "default": "Prof. Dr. Dietrich Grönemeyer"
    },
    {
      "type": "text",
      "id": "expert_role",
      "label": "Expert role",
      "default": "Rückenexperte & Medizinischer Berater, Seven Sundays"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA title",
      "default": "Dein persönliches Sleep System"
    },
    {
      "type": "textarea",
      "id": "cta_desc",
      "label": "CTA description"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Beratung anfragen"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button link"
    }
  ],
  "presets": [
    {
      "name": "SS Expert & Trust",
      "blocks": [
        { "type": "trust_badge", "settings": { "name": "Swiss Engineering", "description": "Entwickelt in der Schweiz, gefertigt in Deutschland. Höchste Präzision." } },
        { "type": "trust_badge", "settings": { "name": "Wissenschaftlich validiert", "description": "+18% PSQI Score. Peer-reviewed Studie mit 43 Elite-Athleten." } },
        { "type": "trust_badge", "settings": { "name": "Personalisiert für dich", "description": "Modulares System. In-Home Beratung. Kein Standard – nur dein Schlaf." } }
      ]
    }
  ]
}
{% endschema %}
