                                    {% endif %}
                                    {% if selected_product_sec != blank %}
                                    <div class="pairs-item" data-variant-id="{{ variant_id_sec }}">
                                        <div class="img-wrapper">
                                          <img width="72" height="40" src="{{ selected_product_sec.featured_image | img_url: 'small' }}" alt="" loading="lazy">
                                        </div>
                                        <div class="content">
                                            <div class="text text-sm"><b>{{ selected_product_sec.title }}</b></div>
                                            <div class="text text-sm">{{ subttile_sec }}</div>
                                        </div>
                                        <div class="btn btn-third">
                                            <b>+ {{ selected_product_sec.price | money }}</b>
                                        </div>
                                    </div>
                                    {% endif %}
                                    {% if selected_product_third != blank %}
                                    <div class="pairs-item" data-variant-id="{{ variant_id_third }}">
                                        <div class="img-wrapper">
                                          <img width="72" height="40" src="{{ selected_product_third.featured_image | img_url: 'small' }}" alt="" loading="lazy">
                                        </div>
                                        <div class="content">
                                            <div class="text text-sm"><b>{{ selected_product_third.title }}</b></div>
                                            <div class="text text-sm">{{ subttile_third }}</div>
                                        </div>
                                        <div class="btn btn-third">
                                            <b>+ {{ selected_product_third.price | money }}</b>
                                        </div>
                                    </div>
                                    {% endif %}
