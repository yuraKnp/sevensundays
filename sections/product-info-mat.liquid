
{% assign number_slide_images = section.settings.number_slide_images %}

{%- assign slider_tags = section.settings.slider_tags | split: ',' -%}

{%- capture block_id_list -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'collapsible_tab_a_s' -%}
      {{ block.id }}{% unless forloop.last %},{% endunless %}
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}
{%- assign block_ids = block_id_list | strip_newlines | replace: ' ', '' | split: ',' -%}

{%- capture block_id_list_drop -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'collapsible_tab' -%}
      {{ block.id }}{% unless forloop.last %},{% endunless %}
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}
{%- assign block_ids_drop = block_id_list_drop | strip_newlines | replace: ' ', '' | split: ',' -%}


{%- assign product_form_id = 'product-form-' | append: section.id -%}

{%- assign doubled_price = product.selected_or_first_available_variant.price | times: 2 -%}



<div class="section sp-sec">
    <div class="container">
        <div class="row justify-content-between">
            <div class="col-lg-7">
                <div class="swiper-entry pd-slider hide-mobile">
                    <div class="swiper-container" data-options='{ 
                        "slidesPerView": 1.05,
                        "spaceBetween": 8,
                        "breakpoints":{
                            "576":{"spaceBetween": 8, "slidesPerView": 1.1},
                            "992":{"spaceBetween": 8, "slidesPerView": 1},
                            "1200":{"spaceBetween": 8, "slidesPerView": 1}
                        }}'>
                        <div class="swiper-wrapper">
                            {% for media in product.media limit: number_slide_images %}
                            {%- assign current_index = forloop.index0 -%}
                            {%- assign current_desc = slider_tags[current_index] | strip -%}
                            <div class="swiper-slide">
                                <div class="pd-main-img">
                                    {% if current_desc != blank %}  
                                    <div class="tags">
                                        <span>{{ current_desc }}</span>
                                    </div>
                                    {% endif %}
                                    <picture>
                                        <source srcset="{{ media | img_url: 'master' }}" type="{{ media.preview_image.format }}">
                                        <img width="380" height="240" src="#" alt="" loading="eager">
                                    </picture>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="swiper-pagination swiper-pagination-relative d-none"></div>
                </div>
                <div class="swiper-entry pd-slider mobile-only-info">
                    <div class="swiper-container" data-options='{ 
                        "slidesPerView": 1.05,
                        "spaceBetween": 8,
                        "breakpoints":{
                            "576":{"spaceBetween": 8, "slidesPerView": 1.1},
                            "992":{"spaceBetween": 8, "slidesPerView": 1},
                            "1200":{"spaceBetween": 8, "slidesPerView": 1}
                        }}'>
                        <div class="swiper-wrapper">
                            {% for media in product.media %}
                            {%- assign current_index = forloop.index0 -%}
                            {%- assign current_desc = slider_tags[current_index] | strip -%}
                            <div class="swiper-slide">
                                <div class="pd-main-img">
                                    {% if current_desc != blank %}  
                                    <div class="tags">
                                        <span>{{ current_desc }}</span>
                                    </div>
                                    {% endif %}
                                    <picture>
                                        <source srcset="{{ media | img_url: 'master' }}" type="{{ media.preview_image.format }}">
                                        <img width="380" height="240" src="#" alt="" loading="eager">
                                    </picture>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="swiper-pagination swiper-pagination-relative d-none"></div>
                </div>


                {% if product.media != blank %}
                <div class="row product-row hide-lg">
                    {%- assign start_index = number_slide_images -%}
                    {%- for media in product.media offset: start_index -%}
                    <div class="col-md-6">
                        <div class="simple-img size5">
                            {%- if media.media_type == 'image' -%}
                            <picture>
                                <source srcset="{{ media | img_url: 'master' }}" type="{{ media.format }}">
                                <img width="380" height="240" src="#" alt="" loading="lazy">
                            </picture>
                            {% endif %}
                        </div>
                    </div>
                  {% endfor %}
                </div>
                {%  endif %}
            </div>
            <div class="col-lg-5">
                <div class="pd-detail-info">
                    <div class="title-shortcode mb-0">
                        {%- for block in section.blocks -%}
                          {%- case block.type -%}
                            {%- when 'rating' -%}

                            {% comment %} <div class="ruk_rating_snippet" data-sku="{{ product.handle }};{{ product.variants | map: 'sku' | join: ';' }};{{ product.variants | map: 'id' | join: ';' }}"></div> {% endcomment %}
                            <div class="ruk_rating_snippet" data-sku="{{ product.id }};{{ product.handle }};{{ product.variants | map: 'sku' | join: ';' }};{{ product.variants | map: 'id' | join: ';' }}"></div>

                            {%- when 'title' -%}
                            <div class="title-with-rating">
                              <h1 class="h2 title">{{ product.title | escape }}</h1>
                              {%- if block.settings.trustpilot -%}
                                <div class="trustpilot-widget" data-locale="de-DE" data-template-id="53aa8807dec7e10d38f59f32" data-businessunit-id="5ff5d1f3b391a00001aac82e" data-style-height="60px" data-style-width="100px" data-token="4af8d245-a721-439b-962b-55d6ee830678">  <a href="" target="_blank" rel="noopener">Trustpilot</a></div>
                              {%- endif -%}
                            </div>
                            {% comment %} {%- when 'price' -%}
                            <div class="text text-md">
                              <div id="price-{{ section.id }}">
                                {%- render 'price',
                                  product: product,
                                  use_variant: true,
                                  show_badges: true,
                                  price_class: 'price--large'
                                -%}
                              </div>
                            </div> {% endcomment %}
                            {%-  when 'description' -%}
                            {%- if product.description -%}
                            <div class="text product-description">
                              <div class="content">
                              {{ product.description }}
                              </div>
                              <div class="btn btn-third product-description-open" data-toggle-more="{{ 'products.facets.show_more' | t }}" data-toggle-less="{{ 'products.facets.show_less' | t -}}">
                                  <b>{{ 'products.facets.show_more' | t }}</b>
                              </div>
                            </div>
                            {%- endif -%}
                          {% endcase %}
                        {% endfor %}
                    </div>
                    {% for option in product.options_with_values %}
                    <div class="quantity-wrapp product-option size2" data-option-index="{{ forloop.index0 }}">
                          {% if option.name == "Size" %}
                            <div class="text"><b>Größe</b></div>

                            <div class="size-type-buttons text">
                              <button type="button" class="size-type-btn active" data-type="Single">Einzelbett</button>
                              <button type="button" class="size-type-btn" data-type="Double">Doppelbett</button>
                            </div>

                            <select class="size-select" style="display:none" hidden>
                              {% for value in option.values %}
                                {% if value contains '(Single)' %}
                                  <option value="{{ value }}" data-size-type="Single">{{ value | remove: ' (Single)' }}</option>
                                {% endif %}
                              {% endfor %}
                              {% for value in option.values %}
                                {% if value contains '(Double)' %}
                                  <option value="{{ value }}" data-size-type="Double">{{ value | remove: ' (Double)' }}</option>
                                {% endif %}
                              {% endfor %}
                            </select>
                            <div class="size-select-wrap text"></div>

                            {% comment %} Hidden items keep the existing variant JS working unchanged {% endcomment %}
                            <div class="quantity number" style="display:none">
                              {% assign size_first_single_active = false %}
                              {% for value in option.values %}
                                {% if value contains '(Single)' and size_first_single_active == false %}
                                  <div class="quantity-item active" data-value="{{ value }}">
                                    <div class="text"><b>{{ value }}</b></div>
                                  </div>
                                  {% assign size_first_single_active = true %}
                                {% else %}
                                  <div class="quantity-item" data-value="{{ value }}">
                                    <div class="text"><b>{{ value }}</b></div>
                                  </div>
                                {% endif %}
                              {% endfor %}
                            </div>
                        {% elsif option.name == "Modular sleep system" %}
                            <div class="motto">{{ option.name }}:</div>
                            <div class="quantity number">
                                {% for value in option.values %}
                                <div class="quantity-item {% if forloop.first %}active{% endif %}" data-value="{{ value }}">
                                    <div class="text"><b>{{ value }}</b></div>
                                </div>
                                {% endfor %}
                            </div>
                            <div class="quantity-wrapp size2">
                                <div id="classic-mode" class="motto">
                                    <span class="data"></span>
                                    <span class="ch-box-tooltip" data-tooltip-txt="Immer enthalten: 5-Zonen-Layer und Stretch-Layer – sie bilden die ergonomische Basis. Der individuelle Komfort wird über den Komfort-Layer gesteuert.">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                            <path d="M8 0C6.41775 0 4.87104 0.469192 3.55544 1.34824C2.23985 2.22729 1.21447 3.47672 0.608967 4.93853C0.00346629 6.40034 -0.15496 8.00887 0.153721 9.56072C0.462403 11.1126 1.22433 12.538 2.34315 13.6569C3.46197 14.7757 4.88743 15.5376 6.43928 15.8463C7.99113 16.155 9.59966 15.9965 11.0615 15.391C12.5233 14.7855 13.7727 13.7602 14.6518 12.4446C15.5308 11.129 16 9.58225 16 8C15.9977 5.87897 15.1541 3.84547 13.6543 2.34568C12.1545 0.845886 10.121 0.00229405 8 0ZM8 14.6667C6.68146 14.6667 5.39253 14.2757 4.2962 13.5431C3.19987 12.8106 2.34539 11.7694 1.84081 10.5512C1.33622 9.33305 1.2042 7.99261 1.46144 6.6994C1.71867 5.40619 2.35361 4.21831 3.28596 3.28596C4.21831 2.35361 5.4062 1.71867 6.6994 1.46143C7.99261 1.2042 9.33305 1.33622 10.5512 1.8408C11.7694 2.34539 12.8106 3.19987 13.5431 4.2962C14.2757 5.39253 14.6667 6.68146 14.6667 8C14.6647 9.76752 13.9617 11.4621 12.7119 12.7119C11.4621 13.9617 9.76752 14.6647 8 14.6667Z" fill="currentColor"/>
                                            <path d="M8.4767 3.37522C8.09225 3.30518 7.69711 3.32048 7.31923 3.42005C6.94135 3.51962 6.58997 3.70102 6.28996 3.95142C5.98995 4.20183 5.74864 4.5151 5.5831 4.86909C5.41757 5.22307 5.33186 5.60911 5.33203 5.99989C5.33203 6.1767 5.40227 6.34627 5.52729 6.47129C5.65232 6.59632 5.82189 6.66656 5.9987 6.66656C6.17551 6.66656 6.34508 6.59632 6.4701 6.47129C6.59513 6.34627 6.66536 6.1767 6.66536 5.99989C6.6652 5.80374 6.70831 5.60997 6.79163 5.43239C6.87494 5.25482 6.99641 5.09781 7.14738 4.97257C7.29834 4.84733 7.47507 4.75695 7.66498 4.70785C7.85489 4.65876 8.05329 4.65217 8.24603 4.68856C8.50939 4.73968 8.75153 4.86815 8.94153 5.05755C9.13153 5.24695 9.26075 5.48869 9.3127 5.75189C9.36516 6.02816 9.32894 6.31394 9.2092 6.56838C9.08946 6.82282 8.89235 7.03289 8.64603 7.16856C8.23814 7.40487 7.90109 7.74623 7.66998 8.15709C7.43887 8.56795 7.32217 9.03326 7.33203 9.50456V9.99989C7.33203 10.1767 7.40227 10.3463 7.52729 10.4713C7.65232 10.5963 7.82189 10.6666 7.9987 10.6666C8.17551 10.6666 8.34508 10.5963 8.4701 10.4713C8.59513 10.3463 8.66536 10.1767 8.66536 9.99989V9.50456C8.657 9.27256 8.7099 9.04246 8.81874 8.83742C8.92759 8.63237 9.08853 8.45962 9.28537 8.33656C9.76837 8.07127 10.1573 7.66286 10.3988 7.16749C10.6402 6.67212 10.7222 6.11413 10.6336 5.57024C10.5449 5.02635 10.2899 4.52328 9.9037 4.13022C9.51747 3.73715 9.01895 3.4734 8.4767 3.37522Z" fill="currentColor"/>
                                            <path d="M8.66536 11.9997C8.66536 11.6315 8.36689 11.333 7.9987 11.333C7.63051 11.333 7.33203 11.6315 7.33203 11.9997C7.33203 12.3679 7.63051 12.6663 7.9987 12.6663C8.36689 12.6663 8.66536 12.3679 8.66536 11.9997Z" fill="currentColor"/>
                                        </svg>
                                    </span>
                                </div>
                                <div id="classic-mode-desc" class="text text-sm"></div>
                            </div>
                        {% elsif option.name == "Komfort layer" %}
                            <div class="motto">{{ option.name }}:
                                <span class="ch-box-tooltip" data-tooltip-txt="Unverklebtes 3-Schichtsystem mit Rahmen. Zwei Funktions-, ein Komfort-Layer. Lass in Sekunden neue Liegegefühle entstehen.">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                    <path d="M8 0C6.41775 0 4.87104 0.469192 3.55544 1.34824C2.23985 2.22729 1.21447 3.47672 0.608967 4.93853C0.00346629 6.40034 -0.15496 8.00887 0.153721 9.56072C0.462403 11.1126 1.22433 12.538 2.34315 13.6569C3.46197 14.7757 4.88743 15.5376 6.43928 15.8463C7.99113 16.155 9.59966 15.9965 11.0615 15.391C12.5233 14.7855 13.7727 13.7602 14.6518 12.4446C15.5308 11.129 16 9.58225 16 8C15.9977 5.87897 15.1541 3.84547 13.6543 2.34568C12.1545 0.845886 10.121 0.00229405 8 0ZM8 14.6667C6.68146 14.6667 5.39253 14.2757 4.2962 13.5431C3.19987 12.8106 2.34539 11.7694 1.84081 10.5512C1.33622 9.33305 1.2042 7.99261 1.46144 6.6994C1.71867 5.40619 2.35361 4.21831 3.28596 3.28596C4.21831 2.35361 5.4062 1.71867 6.6994 1.46143C7.99261 1.2042 9.33305 1.33622 10.5512 1.8408C11.7694 2.34539 12.8106 3.19987 13.5431 4.2962C14.2757 5.39253 14.6667 6.68146 14.6667 8C14.6647 9.76752 13.9617 11.4621 12.7119 12.7119C11.4621 13.9617 9.76752 14.6647 8 14.6667Z" fill="currentColor"/>
                                    <path d="M8.4767 3.37522C8.09225 3.30518 7.69711 3.32048 7.31923 3.42005C6.94135 3.51962 6.58997 3.70102 6.28996 3.95142C5.98995 4.20183 5.74864 4.5151 5.5831 4.86909C5.41757 5.22307 5.33186 5.60911 5.33203 5.99989C5.33203 6.1767 5.40227 6.34627 5.52729 6.47129C5.65232 6.59632 5.82189 6.66656 5.9987 6.66656C6.17551 6.66656 6.34508 6.59632 6.4701 6.47129C6.59513 6.34627 6.66536 6.1767 6.66536 5.99989C6.6652 5.80374 6.70831 5.60997 6.79163 5.43239C6.87494 5.25482 6.99641 5.09781 7.14738 4.97257C7.29834 4.84733 7.47507 4.75695 7.66498 4.70785C7.85489 4.65876 8.05329 4.65217 8.24603 4.68856C8.50939 4.73968 8.75153 4.86815 8.94153 5.05755C9.13153 5.24695 9.26075 5.48869 9.3127 5.75189C9.36516 6.02816 9.32894 6.31394 9.2092 6.56838C9.08946 6.82282 8.89235 7.03289 8.64603 7.16856C8.23814 7.40487 7.90109 7.74623 7.66998 8.15709C7.43887 8.56795 7.32217 9.03326 7.33203 9.50456V9.99989C7.33203 10.1767 7.40227 10.3463 7.52729 10.4713C7.65232 10.5963 7.82189 10.6666 7.9987 10.6666C8.17551 10.6666 8.34508 10.5963 8.4701 10.4713C8.59513 10.3463 8.66536 10.1767 8.66536 9.99989V9.50456C8.657 9.27256 8.7099 9.04246 8.81874 8.83742C8.92759 8.63237 9.08853 8.45962 9.28537 8.33656C9.76837 8.07127 10.1573 7.66286 10.3988 7.16749C10.6402 6.67212 10.7222 6.11413 10.6336 5.57024C10.5449 5.02635 10.2899 4.52328 9.9037 4.13022C9.51747 3.73715 9.01895 3.4734 8.4767 3.37522Z" fill="currentColor"/>
                                    <path d="M8.66536 11.9997C8.66536 11.6315 8.36689 11.333 7.9987 11.333C7.63051 11.333 7.33203 11.6315 7.33203 11.9997C7.33203 12.3679 7.63051 12.6663 7.9987 12.6663C8.36689 12.6663 8.66536 12.3679 8.66536 11.9997Z" fill="currentColor"/>
                                </svg>
                                </span>
                            </div>
                            <div class="quantity number">
                                {% for value in option.values %}
                                <div class="quantity-item {% if forloop.first %}active{% endif %}" data-value="{{ value }}">
                                    <div class="text"><b>{{ value }}</b></div>
                                </div>
                                {% endfor %}
                            </div>
                            <div id="classic-mode-desc-sec" class="text text-sm"></div>
                        {% endif %}

                    </div>
                    {% endfor %}
                    
                    
                    {% unless product.has_only_default_variant %}
                    {% assign current_variant = product.selected_or_first_available_variant %}
                    <div class="pairs-wrapp" style="display: none">
                        {% comment %} <div class="motto">{{ 'products.product.pairs_best_with_ver' | t }}:</div> {% endcomment %}
                        <div class="pairs">
                            {% for variant in product.variants %}
                            <div class="pairs-item variant {% unless variant.available %}disabled{% endunless %} {% if variant.id == current_variant.id %}active{% endif %}" data-variant-id="{{ variant.id }}">
                                <div class="img-wrapper">
                                  <img width="72" height="40" src="{{ variant.featured_image | img_url: 'small' }}" alt="" loading="lazy">
                                </div>
                                <div class="content">
                                    <div class="text text-sm"><b>{{ variant.title }}</b></div>
                                    <div class="text text-sm">{{ variant.metafields.custom.additional_description }}</div>
                                </div>
                                <div class="btn btn-third">
                                    <b>{{ variant.price | money }}</b>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endunless %}
                    

                    
                    {% assign current_variant = product.selected_or_first_available_variant %}
                    {% if current_variant.available %}
                    <div class="status" style="--clr-status: 61 161 92;">
                        <i></i>
                        <div class="text text-sm"><span>{{- 'products.product.inventory_in_stock' | t -}}</span>,&nbsp;{{- 'products.product.ship' | t -}}</div>
                    </div>
                    {%- for block in section.blocks -%}
                      {%- case block.type -%}
                        {%- when 'price' -%}
                            <div class="price-block">
                                <div class="price">
                                    <div class="caption">{{ 'products.product.total_price' | t }}</div>
                                    <div class="text text-md" id="price-{{ section.id }}"><b>
                                {%- render 'price',
                                  product: product,
                                  use_variant: true,
                                  show_badges: true,
                                  price_class: 'price--large'
                                -%}
                            </b></div>
                                </div>
                                <div class="delivery">
                                    <div class="caption">{{ 'products.product.shipping' | t }}</div>
                                    <div class="text text-sm"><b>zzgl. 149 €</b></div>
                                    <div class="text text-sm">{{ 'products.product.remove_matrass' | t }}</div>
                                </div>
                            </div>
                      {% endcase %}
                    {% endfor %}
                    {%- for block in section.blocks -%}
                      {%- case block.type -%}
                        {%- when 'buy_buttons' -%}
                          {%- render 'buy-buttons',
                            block: block,
                            product: product,
                            product_form_id: product_form_id,
                            section_id: section.id,
                            show_pickup_availability: true
                          -%}
                          
                        {% if section.settings.button_after_add_to_cart != blank and section.settings.button_after_add_to_cart_text != blank %}
                        <a href="{{ section.settings.button_after_add_to_cart }}" target="_blank" class="btn btn-secondary btn-block add-cart">
                            <b>{{ section.settings.button_after_add_to_cart_text }}</b>
                        </a>
                        {% endif %}
                      {% endcase %}
                    {% endfor %}
                    {% else %}
                    <div class="status" style="--clr-status: 185, 28, 28;">
                        <i></i>
                        <div class="text text-sm"><span>{{- 'products.product.sold_out' | t -}}</span></div>
                    </div>
                    {%  endif %}

                    {%- if block_ids.size > 0 -%}
                    <div class="pd-delivery">
                        {%- for id in block_ids -%}
                        {%- assign current_block = section.blocks | where: "id", id | first -%}
                        
                        <div class="delivery-item {{ id }}">
                            {%- if current_block.settings.icon != blank -%}
                            <img width="20" height="20" src="{{ current_block.settings.icon | img_url: '40x40' }}" alt="">
                            {%- endif -%}
                            <div class="text">{{ current_block.settings.content }}</div>
                        </div>
                        {%- endfor -%}
                    </div>
                    {%- endif -%}

                    {%- for block in section.blocks -%}
                      {%- case block.type -%}
                        {%- when 'info_after_add_to_cart' -%}
                          {% assign icon = block.settings.icon %}
                          {% assign title = block.settings.title %}
                          {% assign content = block.settings.content %}

                          {%  if icon != blank and title != blank %}
                            <div class="pairs-wrapp">                             
                                <div class="pairs">
                                    <div class="pairs-item-add">
                                        <div class="img-wrapper">
                                          <img width="72" height="40" src="{{ icon | img_url: 'small' }}" alt="" loading="lazy">
                                        </div>
                                        <div class="content">
                                            <div class="text text-sm"><b>{{ title }}</b></div>
                                            <div class="text text-sm">{{ content }}</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                          {%  endif %}

                        {%- when 'pairs_best_with' -%}
                          {% assign selected_product = block.settings.upsell_product %}
                          {% assign selected_product_sec = block.settings.upsell_product_sec %}
                          {% assign selected_product_third = block.settings.upsell_product_third %}
                          {% assign upsell_variant_id = block.settings.upsell_variant_id %}
                          {% assign upsell_variant_id_sec = block.settings.upsell_variant_id_sec %}
                          {% assign upsell_variant_id_third = block.settings.upsell_variant_id_third %}

                          {% assign variant_id = selected_product.selected_or_first_available_variant.id %}
                          {% assign subttile = selected_product.metafields.my_fields.subtitle %}
                          {% if upsell_variant_id != blank %}
                            {% assign variant_id = upsell_variant_id | plus: 0 %}
                            {% assign selected_product = selected_product.variants | where: "id", variant_id | first %}
                            {% comment %} <pre>{{ selected_product.variants | json }}</pre> {% endcomment %}
                            {% assign subttile = selected_product.metafields.custom.additional_description %}
                          {% endif %}

                          {% assign subttile_sec = selected_product_sec.metafields.my_fields.subtitle %}
                          {% assign variant_id_sec = selected_product_sec.selected_or_first_available_variant.id %}
