<style>
  /* Type toggle buttons — mirror .quantity container + .quantity-item (size2 variant) */
  .size-type-buttons {
    display: flex;
    align-items: center;
    padding: 4px;
    background-color: var(--clr-white);
    border-radius: var(--rd-1);
  }
  .size-type-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0;
    width: 50%;
    min-height: 42px;
    padding: var(--sp-12) var(--sp-16);
    border-radius: var(--rd-1);
    background-color: var(--clr-white);
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    font-weight: 700;
    transition: var(--transition-1);
  }
  .size-type-btn.active {
    background-color: #EEEAE3;
    cursor: inherit;
  }
  @media (min-width: 1200px) {
    .size-type-btn:not(.active):hover { opacity: 0.8; }
  }

  /* Custom size dropdown */
  .size-select-wrap {
    display: flex;
    align-items: center;
    padding: 4px;
    background-color: var(--clr-white);
    border-radius: var(--rd-1);
    position: relative;
  }
  .size-select-wrap.open {
    border-radius: var(--rd-1) var(--rd-1) 0 0;
  }
  .size-custom-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    width: 100%;
    min-height: 42px;
    padding: var(--sp-12) var(--sp-16);
    border-radius: var(--rd-1);
    background-color: var(--clr-white);
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    font-weight: 700;
    user-select: none;
    transition: border-radius 0.15s;
  }
  .size-select-wrap.open .size-custom-trigger {
    border-radius: var(--rd-1) var(--rd-1) 0 0;
  }
  .size-custom-trigger svg {
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .size-select-wrap.open .size-custom-trigger svg {
    transform: rotate(180deg);
  }
  .size-custom-dropdown {
    display: none;
    position: absolute;
    top: calc(100% - 4px);
    left: 0;
    right: 0;
    background-color: var(--clr-white);
    border-radius: 0 0 var(--rd-1) var(--rd-1);
    overflow: hidden;
    z-index: 100;
  }
  .size-select-wrap.open .size-custom-dropdown {
    {% comment %} display: block; {% endcomment %}
    display: flex;
    flex-direction: column;
  }
  .size-custom-option {
    padding: var(--sp-12) var(--sp-16);
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    font-weight: 700;
    transition: background-color 0.15s;
  }
  .size-custom-option:hover,
  .size-custom-option.active {
    background-color: #EEEAE3;
  }
  @media (max-width: 767px) {
    .size-type-btn       { min-height: 60px; padding-block: 10px; }
    .size-custom-trigger { min-height: 60px; }
  }

  .size-custom-trigger .text span{
    color: #1E2227;
  }
</style>

