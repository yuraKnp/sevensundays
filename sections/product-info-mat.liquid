<script>
document.addEventListener('DOMContentLoaded', function () {

  const sectionId = "{{ section.id }}";

  document.querySelectorAll('.pairs-item.variant').forEach(item => {
    item.addEventListener('click', function () {

      if (this.classList.contains('disabled')) return;

      const variantId = this.dataset.variantId;

      fetch(`${window.location.pathname}?variant=${variantId}&section_id=${sectionId}`)
        .then(response => response.text())
        .then(html => {

          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');

          const newPrice = doc.querySelector('#price-' + sectionId);
          const currentPrice = document.querySelector('#price-' + sectionId);

          if (newPrice && currentPrice) {
            currentPrice.innerHTML = newPrice.innerHTML;
          }

        });

      // update hidden input
      const idInput = document.querySelector('input[name="id"]');
      if (idInput) idInput.value = variantId;

    });
  });

});
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {

  const product = window.productData;
  const sectionId = "{{ section.id }}";

  let selectedOptions = new Array(product.options.length).fill(null);

  document.querySelectorAll('.product-option').forEach((optionEl, index) => {
    const active = optionEl.querySelector('.quantity-item.active');
    if (active) {
      selectedOptions[index] = active.dataset.value;
    }
  });

  updateVariant();

  document.querySelectorAll('.quantity-item').forEach(item => {
    item.addEventListener('click', function () {

      const parent = this.closest('.product-option');
      const optionIndex = parseInt(parent.dataset.optionIndex);

      parent.querySelectorAll('.quantity-item').forEach(el => el.classList.remove('active'));
      this.classList.add('active');

      selectedOptions[optionIndex] = this.dataset.value;

      updateVariant();
    });
  });

  function updateVariant() {
    const variant = product.variants.find(v => {
      return v.options.every((opt, i) => opt === selectedOptions[i]);
    });

    if (!variant) {
      console.log('No matching variant', selectedOptions);
      return;
    }

    const idInput = document.querySelector('input[name="id"]');
    if (idInput) idInput.value = variant.id;

    const labelEl = document.getElementById('classic-mode');
    const descEl = document.getElementById('classic-mode-desc');
    const descElSec = document.getElementById('classic-mode-desc-sec');
    
    if (labelEl) {
        const span = labelEl.querySelector('.data');
        if (span) {
            span.textContent = variant.additional_label || '';
        }
    }
    if (descEl) {
        descEl.textContent = variant.additional_label_desc || '';
    }
    if (descElSec) {
        descElSec.textContent = variant.additional_label_sec || '';
    }

    fetch(`${window.location.pathname}?variant=${variant.id}&section_id=${sectionId}`)
      .then(res => res.text())
      .then(html => {
        const doc = new DOMParser().parseFromString(html, 'text/html');

        const newPrice = doc.querySelector('#price-' + sectionId);
        const currentPrice = document.querySelector('#price-' + sectionId);

        if (newPrice && currentPrice) {
          currentPrice.innerHTML = newPrice.innerHTML;
        }
      });

    const url = new URL(window.location);
    url.searchParams.set('variant', variant.id);
    window.history.replaceState({}, '', url);

    updateAvailability(variant);
  }



  function updateAvailability(variant) {
    const statusEl = document.querySelector('.status');

    if (!statusEl) return;

    console.log(variant.available);

    if (variant.available) {
      statusEl.style.setProperty('--clr-status', '61 161 92');
      statusEl.querySelector('span').textContent = window.translations.inStock;
    } else {
      statusEl.style.setProperty('--clr-status', '185 28 28');
      statusEl.querySelector('span').textContent = window.translations.soldOut;
    }
  }

});
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var hiddenSelect = document.querySelector('.size-select');
  var typeButtons  = document.querySelectorAll('.size-type-btn');
  var selectWrap   = document.querySelector('.size-select-wrap');

  if (!hiddenSelect || !typeButtons.length || !selectWrap) return;

  // Snapshot all options from the server-rendered hidden select
  var allSizeOptions = Array.from(hiddenSelect.options).map(function (opt) {
    return { value: opt.value, text: opt.textContent.trim(), type: opt.dataset.sizeType };
  });

  // Build custom dropdown inside .size-select-wrap
  var trigger = document.createElement('div');
  trigger.className = 'size-custom-trigger';
  trigger.innerHTML =
    '<span class="size-custom-value"></span>' +
    '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">' +
      '<path d="M3 6l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>' +
    '</svg>';

  var dropdown = document.createElement('div');
  dropdown.className = 'size-custom-dropdown';

  selectWrap.appendChild(trigger);
  selectWrap.appendChild(dropdown);

  var valueSpan = trigger.querySelector('.size-custom-value');

  // Init with Single options
  populateDropdown(optionsFor('Single'));

  // Open / close
  trigger.addEventListener('click', function () {
    selectWrap.classList.toggle('open');
  });
  document.addEventListener('click', function (e) {
    if (!selectWrap.contains(e.target)) selectWrap.classList.remove('open');
  });

  // Type button clicks
  typeButtons.forEach(function (btn) {
    btn.addEventListener('click', function () {
      typeButtons.forEach(function (b) { b.classList.remove('active'); });
      this.classList.add('active');
      var opts = optionsFor(this.dataset.type);
      populateDropdown(opts);
      if (opts.length) selectValue(opts[0].value);
    });
  });

  function optionsFor(type) {
    return allSizeOptions.filter(function (o) { return o.type === type; });
  }

  function populateDropdown(options) {
    dropdown.innerHTML = '';
    options.forEach(function (opt, i) {
      var el = document.createElement('div');
      el.className = 'size-custom-option' + (i === 0 ? ' active' : '');
      el.dataset.value = opt.value;
      el.textContent = opt.text;
      el.addEventListener('click', function () {
        selectValue(opt.value);
        selectWrap.classList.remove('open');
      });
      dropdown.appendChild(el);
    });
    if (options.length) valueSpan.textContent = options[0].text;
  }

  function selectValue(value) {
    var opt = allSizeOptions.find(function (o) { return o.value === value; });
    if (opt) valueSpan.textContent = opt.text;

    dropdown.querySelectorAll('.size-custom-option').forEach(function (el) {
      el.classList.toggle('active', el.dataset.value === value);
    });

    // Delegate to hidden .quantity-item — existing variant JS handles everything from here
    var item = document.querySelector('.quantity-item[data-value="' + value + '"]');
    if (item) item.click();
  }
});
</script>

