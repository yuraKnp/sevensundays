{{ 'sleep-suite.css' | asset_url | stylesheet_tag }}
<section class="section">
  <div class="container text-center">

    {%- if section.settings.pill_text != blank -%}
    <div class="ss-hero__label">
      <span class="ss-pill">{{ section.settings.pill_text }}</span>
    </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
    <h1 class="ss-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
    <p class="ss-hero__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- if section.settings.quote_text != blank -%}
    <div class="ss-hero__quote">
      <div class="ss-hero__quote-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="rgba(30,34,39,0.6)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 8v4M12 16h.01"/>
        </svg>
      </div>
      <p>{{ section.settings.quote_text }}</p>
    </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "SS Hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "pill_text",
      "label": "Pill label",
      "default": "Sleep Suite · Seven Sundays"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Unlock <em>Better Sleep.</em><br>Discover your best self.</p>"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Jeder Mensch ist einzigartig – deshalb ist personalisierter Schlaf der Schlüssel zu maximaler Regeneration."
    },
    {
      "type": "richtext",
      "id": "quote_text",
      "label": "Quote text",
      "default": "<p><strong>Erst wenn der Körper ideal gelagert ist</strong>, Muskeln, Sehnen und Faszien maximal entspannt sind – erst dann entfaltet sich das volle Regenerationspotential.</p>"
    }
  ],
  "presets": [
    {
      "name": "SS Hero"
    }
  ]
}
{% endschema %}
