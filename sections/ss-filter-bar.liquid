<div class="ss-filter">
  <div class="container">
    <div class="ss-filter__inner">

      {%- if section.settings.label != blank -%}
      <span class="ss-filter__label">{{ section.settings.label }}</span>
      {%- endif -%}

      <button class="ss-filter__btn is-active" data-filter="all">{{ section.settings.all_label }}</button>

      {%- for block in section.blocks -%}
        {%- if block.type == 'filter_button' -%}
        <button class="ss-filter__btn" data-filter="{{ block.settings.filter }}" {{ block.shopify_attributes }}>
          {{ block.settings.label }}
        </button>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</div>

<script>
(function () {
  function initFilter() {
    var filterBtns    = document.querySelectorAll('.ss-filter__btn');
    var journeyTabs   = document.querySelectorAll('.ss-journey__tab');
    var productSects  = document.querySelectorAll('.ss-section[data-category]');

    function applyFilter(filter) {
      filterBtns.forEach(function (btn) {
        btn.classList.toggle('is-active', btn.dataset.filter === filter);
      });

      journeyTabs.forEach(function (tab, i) {
        tab.classList.toggle('is-active', filter === 'all' ? i === 0 : tab.dataset.filter === filter);
      });

      productSects.forEach(function (section) {
        section.style.display = (filter === 'all' || section.dataset.category === filter) ? '' : 'none';
      });
    }

    filterBtns.forEach(function (btn) {
      btn.addEventListener('click', function () { applyFilter(this.dataset.filter); });
    });

    journeyTabs.forEach(function (tab) {
      tab.addEventListener('click', function () { applyFilter(this.dataset.filter); });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFilter);
  } else {
    initFilter();
  }
}());
</script>

{% schema %}
{
  "name": "SS Filter Bar",
  "blocks": [
    {
      "type": "filter_button",
      "name": "Filter button",
      "settings": [
        {
          "type": "text",
          "id": "filter",
          "label": "Filter value",
          "info": "Must match the category value on the product section"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Button label"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Prefix label",
      "default": "Zeige:"
    },
    {
      "type": "text",
      "id": "all_label",
      "label": "\"All\" button label",
      "default": "Alle Produkte"
    }
  ],
  "presets": [
    {
      "name": "SS Filter Bar",
      "blocks": [
        { "type": "filter_button", "settings": { "filter": "system", "label": "Das System" } },
        { "type": "filter_button", "settings": { "filter": "schlafklima", "label": "Schlafklima" } },
        { "type": "filter_button", "settings": { "filter": "sinne", "label": "Sinne & Geist" } },
        { "type": "filter_button", "settings": { "filter": "recovery", "label": "Recovery" } }
      ]
    }
  ]
}
{% endschema %}
